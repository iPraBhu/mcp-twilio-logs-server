{
  "name": "mcp-twilio-logs-server",
  "version": "0.1.0",
  "description": "Read-only MCP stdio server for inspecting Twilio Messaging and Verify logs.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "homepage": "https://github.com/iPraBhu/mcp-twilio-logs-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iPraBhu/mcp-twilio-logs-server.git"
  },
  "bugs": {
    "url": "https://github.com/iPraBhu/mcp-twilio-logs-server/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "twilio",
    "messaging",
    "verify",
    "logs",
    "stdio"
  ],
  "bin": {
    "mcp-twilio-logs-server": "./dist/index.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": "./dist/server.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test test/*.test.ts",
    "check": "npm run build && npm run typecheck && npm run test",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "twilio": "5.13.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.9.2",
    "tsx": "4.20.6",
    "typescript": "6.0.2"
  }
}
